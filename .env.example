DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
QWEN_CHAT_MODEL=qwen3.6-flash-2026-04-16
QWEN_CLEANING_STRATEGY_MODEL=qwen3.5-plus-2026-04-20
QWEN_GLOBAL_MODEL=qwen3.6-flash-2026-04-16
QWEN_VL_MODEL=qwen-vl-max
QWEN_MATH_MODEL=qwen-math-plus
QWEN_TEMPERATURE=0.2
ENABLE_CONTEXT_FOLLOWUP_TOOLS=0

# Local MinerU PDF parser backend. Keep disabled until MinerU is installed locally.
MINERU_ENABLED=0
MINERU_BACKEND=cli
MINERU_BIN=mineru
MINERU_TIMEOUT_SECONDS=900
# Override this when your local MinerU CLI uses a different command shape.
MINERU_COMMAND_TEMPLATE='"{bin}" -p "{input}" -o "{output}" -b pipeline'

# Current affairs search planner/summarizer. Defaults to ROUTER_* or DEEPSEEK_* when unset.
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
CURRENT_AFFAIRS_MODEL=deepseek-v4-flash

# Politics final-answer composer. Defaults to DEEPSEEK_* and deepseek-v4-flash.
POLITICS_ANSWER_MODEL=deepseek-v4-flash
# POLITICS_ANSWER_API_KEY=your_deepseek_api_key
# POLITICS_ANSWER_BASE_URL=https://api.deepseek.com

# News search backend for get_current_affairs.
# Supported: brave, bing, tavily
NEWS_SEARCH_PROVIDER=brave
NEWS_SEARCH_API_KEY=your_news_search_api_key
NEWS_SEARCH_MAX_WORKERS=5
NEWS_SEARCH_QUERY_BUDGET=12
NEWS_SEARCH_MAX_REQUESTS=12
NEWS_SEARCH_RESULTS_PER_QUERY=5
NEWS_SEARCH_MIN_EVIDENCE=3
NEWS_SEARCH_ENABLE_FALLBACK=true
NEWS_SEARCH_FALLBACK_QUERY_BUDGET=6
NEWS_SEARCH_FALLBACK_MAX_REQUESTS=6
NEWS_SEARCH_LOG_ENABLED=true
NEWS_SEARCH_FETCH_PAGES=8
NEWS_FETCH_MAX_PAGES=8
