EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
QWEN_CHAT_MODEL=qwen3.6-flash-2026-04-16
QWEN_CLEANING_STRATEGY_MODEL=qwen3.6-plus-2026-04-02
