DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
MATERIALS_VECTOR_INDEX_ENABLED=1
MATERIALS_EMBEDDING_MODEL=text-embedding-v4
MATERIALS_EMBEDDING_DIMENSIONS=1024
MATERIALS_EMBEDDING_BATCH_SIZE=10
MATERIALS_VECTOR_MIN_SCORE=0.55
MATERIALS_SEARCH_DIVERSIFY_HEADINGS=1
MATERIALS_SEARCH_MAX_RESULTS_PER_TABLE=1
MATERIALS_SEARCH_EXPAND_SPLIT_CONTEXT=1
MATERIALS_SEARCH_SPLIT_CONTEXT_MAX_CHARS=4200
MATERIALS_SEARCH_LOG_ENABLED=1
# MATERIALS_SEARCH_LOG_DIR=data/runtime/logs
QWEN_CHAT_MODEL=qwen3.6-flash-2026-04-16
QWEN_CLEANING_STRATEGY_MODEL=qwen3.5-plus-2026-04-20
QWEN_GLOBAL_MODEL=qwen3.6-flash-2026-04-16
QWEN_VL_MODEL=qwen-vl-max
QWEN_MATH_MODEL=qwen-math-plus
QWEN_TEMPERATURE=0.2
ENABLE_CONTEXT_FOLLOWUP_TOOLS=0

# MinerU PDF parser backend.
# Supported backends:
# - cloud: official MinerU API, recommended for speed and larger PDFs.
# - cli: local MinerU CLI fallback.
# - auto: cloud when MINERU_API_TOKEN exists, otherwise cli.
MINERU_ENABLED=0
MINERU_BACKEND=cloud
MINERU_API_TOKEN=your_mineru_api_token
MINERU_API_BASE_URL=https://mineru.net
MINERU_MODEL_VERSION=pipeline
MINERU_LANGUAGE=ch
MINERU_ENABLE_FORMULA=true
MINERU_ENABLE_TABLE=true
MINERU_CLOUD_TIMEOUT_SECONDS=1800
MINERU_CLOUD_POLL_INTERVAL_SECONDS=3
MINERU_CLOUD_FALLBACK_TO_CLI=false

# Local CLI fallback. Keep configured only when MinerU CLI is installed locally.
MINERU_BIN=mineru
MINERU_TIMEOUT_SECONDS=900
# Override this when your local MinerU CLI uses a different command shape.
MINERU_COMMAND_TEMPLATE='"{bin}" -p "{input}" -o "{output}" -b pipeline'

# Current affairs search planner/summarizer. Defaults to ROUTER_* or DEEPSEEK_* when unset.
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
CURRENT_AFFAIRS_MODEL=deepseek-v4-flash

# Politics final-answer composer. Defaults to DEEPSEEK_* and deepseek-v4-flash.
POLITICS_ANSWER_MODEL=deepseek-v4-flash
# POLITICS_ANSWER_API_KEY=your_deepseek_api_key
# POLITICS_ANSWER_BASE_URL=https://api.deepseek.com

# News search backend for get_current_affairs.
# Supported: brave, bing, tavily
NEWS_SEARCH_PROVIDER=brave
NEWS_SEARCH_API_KEY=your_news_search_api_key
NEWS_SEARCH_MAX_WORKERS=5
NEWS_SEARCH_QUERY_BUDGET=12
NEWS_SEARCH_MAX_REQUESTS=12
NEWS_SEARCH_RESULTS_PER_QUERY=5
NEWS_SEARCH_MIN_EVIDENCE=3
NEWS_SEARCH_ENABLE_FALLBACK=true
NEWS_SEARCH_FALLBACK_QUERY_BUDGET=6
NEWS_SEARCH_FALLBACK_MAX_REQUESTS=6
NEWS_SEARCH_LOG_ENABLED=true
NEWS_SEARCH_FETCH_PAGES=8
NEWS_FETCH_MAX_PAGES=8
